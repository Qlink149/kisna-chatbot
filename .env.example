# Copy this file to .env in this directory before running the app.
OPENAI_API_KEY=
MONGO_URI=
# Database name (Atlas cluster can host many DBs)
MONGO_DB_NAME=Kisna_Chatbot
# Max chat_history entries stored per user (default 50)
CHAT_HISTORY_MAX_LENGTH=50

# --- AI providers (chat LLM) ---
# Groq-first chat (recommended). OpenAI still needed for KB embeddings below.
# Default: groq | openai
AI_PROVIDER=groq
# Per-agent overrides (empty = use AI_PROVIDER)
AI_PROVIDER_CLASSIFIER=
AI_PROVIDER_GENERAL=groq
AI_FALLBACK_ENABLED=false
AI_FALLBACK_PROVIDER=groq
# Chat models
OPENAI_CHAT_MODEL=gpt-4o-mini
GROQ_API_KEY=
# Multiple Groq keys (comma-separated) — rotates on rate limit / 429
GROQ_API_KEYS=
GROQ_RATE_LIMIT_RETRY_KEYS=true
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
# KB (Chroma) uses OpenAI embeddings — set OPENAI_API_KEY even when chat is Groq-only
KB_ENABLED=
CHROMA_API_KEY=
CHROMA_TENANT=

# --- Gupshup (Dashboard) ---
GUPSHUP_APP_NAME=
GUPSHUP_APP_ID=
# Partner API (webhook script + flows) — see scripts/setup_gupshup_webhook.py
GUPSHUP_PARTNER_TOKEN=
GUPSHUP_PARTNER_EMAIL=
GUPSHUP_PARTNER_CLIENT_SECRET=
GUPSHUP_PARTNER_PASSWORD=
GUPSHUP_PARTNER_APP_TOKEN=
GUPSHUP_TOKEN=
# WhatsApp send API (api.gupshup.io/wa/api/v1/msg) — header apikey
GUPSHUP_API_KEY=
# WhatsApp sender number (E.164 without +). Use GUPSHUP_SOURCE or GUPSHUP_PHONE_NUMBER.
GUPSHUP_PHONE_NUMBER=
GUPSHUP_SOURCE=

# Complaint WhatsApp Flow (set after: python scripts/setup_gupshup_flow.py)
KISNA_DAMAGE_COMPLAINT_FLOW_ID=
# Flow script: GUPSHUP_FLOW_NAME=kisna_damage_complaint
# GUPSHUP_FLOW_CATEGORIES=OTHER
# GUPSHUP_FLOW_JSON_PATH=json/damage_complaint.json

# Budget custom-input WhatsApp Flow (register json/budget_custom_input.json in Meta Business Manager
# → WhatsApp → Flows → Create Flow, then paste the returned Flow ID here)
# When unset, the bot falls back to the plain-text budget prompt.
KISNA_BUDGET_FLOW_ID=

# Register webhook after deploy: python scripts/setup_gupshup_webhook.py
WEBHOOK_URL=
GUPSHUP_WEBHOOK_TAG=kisna-chatbot
GUPSHUP_WEBHOOK_VERSION=3
GUPSHUP_WEBHOOK_MODES=MESSAGE,SENT,DELIVERED,READ,DELETED,FAILED,OTHERS,ENQUEUED
GUPSHUP_WEBHOOK_SHOW_ON_UI=true

# Approved Gupshup OTP template UUID (see send_otp_template.py)
GUPSHUP_OTP_TEMPLATE_ID=

# Register this template in Gupshup dashboard before use (see send_kisna_welcome_template.py).
# Update the template text in Gupshup to match KIA's welcome message — code only references the ID.
KISNA_WELCOME_TEMPLATE_ID=

# UTILITY templates (see scripts/setup_gupshup_template.py)
VENDOR_NOTIFICATION_TEMPLATE_ID=
CUSTOMER_NOTIFICATION_TEMPLATE_ID=

# Optional in dev; required when ENV_MODE=prod
GUPSHUP_WEBHOOK_SECRET=

# Meta phone_number_id from webhook metadata (see Vercel logs on first message)
# Example: KISNA_PHONE_NUMBER_ID=451074671429987
KISNA_PHONE_NUMBER_ID=
NKL_PHONE_NUMBER_ID=

CHROMA_API_KEY=
CHROMA_TENANT=
# Clara API (KISNA jewellery catalogue — products, promotions, stores)
KISNA_CLARA_BASE_URL=https://your-clara-host.example
CLARA_API_KEY=your_clara_api_key_here
KISNA_WELCOME_TEMPLATE_ID=<get from Gupshup after registering; update template text to KIA welcome in dashboard>

# Product catalog base URL — GET {KISNA_PRODUCT_API}/search?q=...&limit=10
KISNA_PRODUCT_API=
KISNA_OFFERS_API=
KISNA_STORE_API=
KISNA_WEBSITE_DOMAIN=www.kisna.com

# Cloudinary Fetch — converts .webp product images to JPEG for WhatsApp (no API key needed)
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
KISNA_SUPPORT_PHONE=
KISNA_SUPPORT_EMAIL=support@kisna.com
KISNA_STORE_LOCATOR_URL=https://www.kisna.com/store
KISNA_TRACK_ORDER_URL=
KISNA_ORDER_TRACKING_URL=https://uat-kisna-uat-web.ucxe8k.easypanel.host/

# Callback / video-call WhatsApp Flows (after: python scripts/setup_gupshup_flow.py)
KISNA_CALLBACK_FLOW_ID=
KISNA_VIDEOCALL_FLOW_ID=

# Dynamic Flow data_exchange (filter today's time slots)
# 1) Generate RSA 2048 PEM pair (openssl or Python cryptography); keep private key secret.
# 2) Set KISNA_FLOW_PRIVATE_KEY locally AND on Vercel (PEM; use \n for newlines in one line).
# 3) Deploy so https://<api-host>/whatsapp/flows/data-exchange is live (Meta health-checks it).
# 4) Upload public.pem via Gupshup POST .../partner/app/{APP_ID}/flows/publicKey
#    (JSON body with real PEM newlines; Gupshup returns 201 on success).
# 5) Create NEW flows with endpoint_uri (Gupshup Update Flow ignores endpoint_uri):
#    POST .../flows/  JSON: name, categories, endpoint_uri, application_id, flow_json, publish=true
#    endpoint_uri = https://<api-host>/whatsapp/flows/data-exchange
# 6) Point KISNA_CALLBACK_FLOW_ID / KISNA_VIDEOCALL_FLOW_ID at the new published IDs.
# Note: Do not upload data_api_version 3.0 JSON onto an existing flow until endpoint_uri is set,
# or publish will fail and the flow may drop to DRAFT.
KISNA_FLOW_PRIVATE_KEY=
KISNA_FLOW_PRIVATE_KEY_PASSPHRASE=

# Optional ad-hoc support closures: 2026-12-25:Christmas,2026-11-09:Diwali
KISNA_SUPPORT_HOLIDAYS=

# Outbound link analytics (GA4/GTM on kisna.com)
# Tag every bot-sent kisna.com URL with utm_source + utm_medium only.
KISNA_UTM_ENABLED=true
KISNA_UTM_SOURCE=whatsapp
KISNA_UTM_MEDIUM=kia_bot
KISNA_WEBSITE_HOME_URL=https://www.kisna.com
KISNA_CARE_URL=
KISNA_VTIGER_BASE=
KISNA_VTIGER_TOKEN=
NKL_VTIGER_BASE=
NKL_VTIGER_TOKEN=
SUPER_ADMIN_USERNAME=
SUPER_ADMIN_PASSWORD=
JWT_SECRET_KEY=
SYSTEM_API_KEY=
ENV_MODE=dev

# --- Logging (Vercel: logs go to stdout as single-line JSON) ---
# LOG_LEVEL=DEBUG|INFO|WARNING (default: INFO on Vercel, DEBUG locally)
LOG_LEVEL=
# Log sanitized HTTP request/response bodies (default: true when ENV_MODE=dev)
LOG_HTTP_BODIES=
# Pretty-print JSON logs locally (ignored on Vercel)
LOG_PRETTY=
# Deprecated alias for LOG_HTTP_BODIES (webhook payload logging)
LOG_GUPSHUP_WEBHOOK_PAYLOAD=
