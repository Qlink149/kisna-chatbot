{
  "version": "7.0",
  "data_api_version": "3.0",
  "routing_model": {
    "CALLBACK_REQUEST": []
  },
  "screens": [
    {
      "data": {
        "min_date": {
          "type": "string",
          "__example__": "2026-07-13"
        },
        "time_slots": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {"type": "string"},
              "title": {"type": "string"}
            }
          },
          "__example__": [
            {"id": "14-15", "title": "Afternoon — 2 PM–3 PM"},
            {"id": "15-16", "title": "Afternoon — 3 PM–4 PM"},
            {"id": "16-17", "title": "Afternoon — 4 PM–5 PM"}
          ]
        },
        "slot_error": {
          "type": "string",
          "__example__": ""
        }
      },
      "id": "CALLBACK_REQUEST",
      "terminal": true,
      "title": "Callback Request",
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          {
            "name": "flow_path",
            "type": "Form",
            "children": [
              {
                "type": "TextSubheading",
                "text": "Request a callback from our support team."
              },
              {
                "type": "TextInput",
                "label": "Mobile Number",
                "name": "mobile",
                "required": true,
                "input-type": "text"
              },
              {
                "type": "Dropdown",
                "label": "Reason",
                "name": "reason",
                "required": true,
                "data-source": [
                  {"id": "product_enquiry", "title": "Product Enquiry"},
                  {"id": "order_support", "title": "Order Support"},
                  {"id": "store_assistance", "title": "Store Assistance"},
                  {"id": "exchange_return", "title": "Exchange/Return"},
                  {"id": "other", "title": "Other"}
                ]
              },
              {
                "type": "DatePicker",
                "name": "preferred_date",
                "label": "Preferred Date",
                "required": true,
                "min-date": "${data.min_date}",
                "on-select-action": {
                  "name": "data_exchange",
                  "payload": {
                    "preferred_date": "${form.preferred_date}",
                    "trigger": "date_selected",
                    "mobile": "${form.mobile}",
                    "reason": "${form.reason}"
                  }
                }
              },
              {
                "type": "TextBody",
                "text": "${data.slot_error}"
              },
              {
                "type": "Dropdown",
                "label": "Preferred Time",
                "name": "preferred_time",
                "required": true,
                "data-source": "${data.time_slots}"
              },
              {
                "type": "Footer",
                "label": "Submit",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "mobile": "${form.mobile}",
                    "reason": "${form.reason}",
                    "preferred_date": "${form.preferred_date}",
                    "preferred_time": "${form.preferred_time}",
                    "request_type": "callback"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
